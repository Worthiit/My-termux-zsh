#!/data/data/com.termux/files/usr/bin/bash

PRO_FILE="$HOME/.termux/amv_pro.txt"
touch "$PRO_FILE"

MENU=(
    "َ°™ڈ  [PRO] Add Custom Action"
    "َ±‚ڑ  Return Home"
    "َ°œ—  Go Back"
    "َ°–©  Wi-Fi Config"
    "َ°‚¯  Bluetooth"
    "َ°ƒ   Brightness"
    "َ°“ƒ  Volume/Sound"
    "َ°¢®  Display Sync"
    "َ°‚„  Battery Info"
    "َ°µ…  Send Notify"
    "َ°†§  Developer Core"
    "َ°—§  Date & Time"
    "َ°¥‡  Location"
    "َ°چ›  Storage"
    "َ°’“  System Info"
    "َ°’¦  Airplane Mode"
    "َ°–ں  Browse Web"
    "َ°ˆ±  Force Stop App"
    "َ°‚‍  Do Not Disturb"
    "َ°€ھ  Accessibility"
    "َ°’”  App Manager"
    "َ°€¦  Biometrics/Lock"
    "َ°‹ٹ  Account Sync"
    "َ°€¼  Language/Input"
    "َ°—گ  Privacy Center"
    "$(cat $PRO_FILE 2>/dev/null | cut -d'|' -f1)"
)

CH=$(printf "%s\n" "${MENU[@]}" | fzf --prompt="Android Core > " --height=60% --reverse --border --header="PRO: Tab/Search to find actions fast")

case "$CH" in
    "َ°™ڈ  [PRO] Add Custom Action")
        echo -e "\033[1;33m[!] DEV MODE: Enter path/action (e.g. android.settings.WIFI_SETTINGS)\033[0m"
        read -p "Label: " lab
        read -p "Action Path: " path
        echo "$lab|$path" >> "$PRO_FILE"
        ;;
    "َ±‚ڑ  Return Home") am start -a android.intent.action.MAIN -c android.intent.category.HOME ;;
    "َ°œ—  Go Back") input keyevent 4 ;;
    "َ°–©  Wi-Fi Config") am start -a android.settings.WIFI_SETTINGS ;;
    "َ°‚¯  Bluetooth") am start -a android.settings.BLUETOOTH_SETTINGS ;;
    "َ°ƒ   Brightness") am start -a android.settings.DISPLAY_SETTINGS ;;
    "َ°“ƒ  Volume/Sound") am start -a android.settings.SOUND_SETTINGS ;;
    "َ°¢®  Display Sync") am start -a android.settings.SYNC_SETTINGS ;;
    "َ°‚„  Battery Info") am start -a android.intent.action.POWER_USAGE_SUMMARY ;;
    "َ°µ…  Send Notify") termux-notification -t "Reinhart" -c "Bridge Active" ;;
    "َ°†§  Developer Core") am start -a android.settings.APPLICATION_DEVELOPMENT_SETTINGS ;;
    "َ°—§  Date & Time") am start -a android.settings.DATE_SETTINGS ;;
    "َ°¥‡  Location") am start -a android.settings.LOCATION_SOURCE_SETTINGS ;;
    "َ°چ›  Storage") am start -a android.settings.INTERNAL_STORAGE_SETTINGS ;;
    "َ°’“  System Info") am start -a android.settings.DEVICE_INFO_SETTINGS ;;
    "َ°’¦  Airplane Mode") am start -a android.settings.AIRPLANE_MODE_SETTINGS ;;
    "َ°–ں  Browse Web") echo "URL:"; read u; am start -a android.intent.action.VIEW -d "https://$u" ;;
    "َ°ˆ±  Force Stop App") echo "Pkg:"; read p; am force-stop "$p" ;;
    "َ°‚‍  Do Not Disturb") am start -a android.settings.ZEN_MODE_SETTINGS ;;
    "َ°€ھ  Accessibility") am start -a android.settings.ACCESSIBILITY_SETTINGS ;;
    "َ°’”  App Manager") am start -a android.settings.MANAGE_APPLICATIONS_SETTINGS ;;
    "َ°€¦  Biometrics/Lock") am start -a android.settings.SECURITY_SETTINGS ;;
    "َ°‹ٹ  Account Sync") am start -a android.settings.SYNC_SETTINGS ;;
    "َ°€¼  Language/Input") am start -a android.settings.INPUT_METHOD_SETTINGS ;;
    "َ°—گ  Privacy Center") am start -a android.settings.PRIVACY_SETTINGS ;;
    *)
        ACT=$(grep "^$CH|" "$PRO_FILE" | cut -d'|' -f2)
        [[ -n "$ACT" ]] && am start -a $ACT
        ;;
esac
