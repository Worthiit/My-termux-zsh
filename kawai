#!/data/data/com.termux/files/usr/bin/bash

ART_DIR="$HOME/.termux/ascii"
CURRENT_ART="$HOME/.termux/current_art.txt"

mkdir -p "$ART_DIR"

if [[ "$1" == "-a" || "$1" == "--add" ]]; then
    if [[ -z "$2" ]]; then
        echo -e "\033[1;31m[!] Name the art. Usage: kawai -a <name>\033[0m"
        exit 1
    fi
    echo -e "\033[1;36m[+] Paste your ASCII below, then hit Ctrl+D:\033[0m"
    cat > "$ART_DIR/$2.txt"
    echo -e "\033[1;32m[✔] Added $2 to arsenal.\033[0m"
    exit 0
fi

if [[ "$1" == "-rm" || "$1" == "--remove" ]]; then
    TARGET=$(ls "$ART_DIR" | fzf --prompt="Nuke which art? > " --height=40% --reverse --border)
    if [[ -n "$TARGET" ]]; then
        rm "$ART_DIR/$TARGET"
        echo -e "\033[1;31m[!] $TARGET deleted from arsenal.\033[0m"
    fi
    exit 0
fi

if [ ! -d "$ART_DIR" ] || [ -z "$(ls -A "$ART_DIR" 2>/dev/null)" ]; then
    clear
    echo -e "\033[1;31m[!] Arsenal is empty.\033[0m"
    echo -e "\033[1;33m[i] Ensure your files are in $ART_DIR\033[0m"
    exit 1
fi

clear
SELECTED=$(find "$ART_DIR" -maxdepth 1 -type f -name "*.txt" | fzf \
    --prompt="Select ASCII Art > " \
    --height=100% \
    --layout=reverse \
    --border=none \
    --preview "cat {}" \
    --preview-window=top:50%:wrap:sharp)

if [ -n "$SELECTED" ]; then
    cp "$SELECTED" "$CURRENT_ART"
    clear
    echo -e "\033[1;32m[✔] ASCII Art swapped: $(basename "$SELECTED")\033[0m"
    zsh ~/motd.sh
else
    clear
    echo -e "\033[1;31m[!] Selection aborted.\033[0m"
fi
